# https://www.geeksforgeeks.org/problems/kadanes-algorithm-1587115620/1

class Solution:
    def maxSubarraySum(self, arr):
        # Code here
        maxx = arr[0]
        curr = arr[0]
        for i in range(1,len(arr)):
            
            curr = max(arr[i],arr[i]+curr)
            maxx = max(maxx,curr)
            
        return maxx 
            
