# https://www.geeksforgeeks.org/problems/sandwiched-vowels5158/1

class Solution:
    def SandwichedVowel(self, s):
        vowels = "aeiou"
        result = ""
        
        for i in range(len(s)):
            if (s[i] in vowels and i > 0 and i < len(s)-1 and s[i-1] not in vowels and s[i+1] not in vowels):
                continue
            result += s[i]
        
        return result
